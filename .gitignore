# AI Fitness & Nutrition Coach (Enhanced Prototype)

from datetime import datetime

# ----------------------------
# DATABASE (Simple mock data)
# ----------------------------
calorie_db = {
    "banana": {"calories": 105, "protein": 1, "carbs": 27, "fat": 0},
    "apple": {"calories": 95, "protein": 0, "carbs": 25, "fat": 0},
    "milk": {"calories": 150, "protein": 8, "carbs": 12, "fat": 8},
    "egg": {"calories": 70, "protein": 6, "carbs": 1, "fat": 5},
    "oats": {"calories": 150, "protein": 5, "carbs": 27, "fat": 3},
    "rice": {"calories": 200, "protein": 4, "carbs": 45, "fat": 1},
    "paneer": {"calories": 265, "protein": 18, "carbs": 6, "fat": 20},
    "chicken": {"calories": 165, "protein": 31, "carbs": 0, "fat": 4},
    "bread": {"calories": 80, "protein": 3, "carbs": 15, "fat": 1}
}

# ----------------------------
# CALCULATION ENGINE
# ----------------------------
def analyze_meal(food_items):
    total = {"calories": 0, "protein": 0, "carbs": 0, "fat": 0}
    unknown_items = []

    for item in food_items:
        item = item.strip()

        if item in calorie_db:
            data = calorie_db[item]
            total["calories"] += data["calories"]
            total["protein"] += data["protein"]
            total["carbs"] += data["carbs"]
            total["fat"] += data["fat"]
        else:
            unknown_items.append(item)

    return total, unknown_items


# ----------------------------
# FITNESS ENGINE
# ----------------------------
def fitness_advice(goal, calories):
    goal = goal.lower()

    if goal == "weight loss":
        advice = "Maintain calorie deficit, increase cardio, high protein diet."
        target = 1800
    elif goal == "muscle gain":
        advice = "Eat calorie surplus, focus on strength training, high protein intake."
        target = 2600
    else:
        advice = "Balanced diet with regular exercise (3–5 days/week)."
        target = 2200

    status = "below target" if calories < target else "above target"

    return advice, target, status


# ----------------------------
# REPORT GENERATOR
# ----------------------------
def generate_report(total, goal):
    advice, target, status = fitness_advice(goal, total["calories"])

    print("\n==============================")
    print("   AI FITNESS DAILY REPORT")
    print("==============================")

    print(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    print(f"\nCalories: {total['calories']} kcal")
    print(f"Protein: {total['protein']} g")
    print(f"Carbs: {total['carbs']} g")
    print(f"Fat: {total['fat']} g")

    print(f"\nTarget Calories: {target} kcal")
    print(f"Status: {status}")

    print("\nAI Recommendation:")
    print(advice)


# ----------------------------
# MAIN PROGRAM
# ----------------------------
def main():
    print("=== AI Fitness & Nutrition Coach v2 ===\n")

    food_input = input("Enter food items (comma separated): ").lower()
    food_list = food_input.split(",")

    goal = input("Enter your goal (weight loss / muscle gain / maintenance): ")

    total, unknown = analyze_meal(food_list)

    generate_report(total, goal)

    if unknown:
        print("\n⚠️ Unknown items (not in database):", ", ".join(unknown))

    print("\nNote: This is a prototype system. Future version will integrate real AI models.")


if _name_ == "_main_":
    main()
